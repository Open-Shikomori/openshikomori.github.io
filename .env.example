# Supabase Configuration
# Get these from your Supabase Dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key

# Cloudflare R2 (for audio storage)
# Deploy a Worker from: https://github.com/your-repo/r2-worker
VITE_R2_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# OpenRouter API (for AI reasoning and transcriptions)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key
